---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { artFor } from '../lib/art.js';
import { homePhotos, textTiles, highlights, avatar, HEART } from '../lib/gallery.js';

const projects = (await getCollection('work', ({ data }) => !data.draft)).sort((a, b) => a.data.order - b.data.order);
const first = (s) => s.split('. ')[0].replace(/\.$/, '') + '.';
const coverFor = { 'hush-jewels': '/photos/gold_hoops_jewelry_collection.jpg' };

// Build an interleaved feed for a lively masonry. Home and Explore draw from
// disjoint photo sets (see lib/gallery.js), so nothing repeats site-wide.
type Tile = any;
const P = projects.map((e) => ({ t: 'project', e }));
const PH = homePhotos.map((p, i) => ({ t: 'photo', p, i }));
const TX = textTiles.map((x, i) => ({ t: 'text', x, i }));
const feed: Tile[] = [];
const order = [P[0], PH[0], TX[0], P[1], PH[1], PH[2], TX[1], P[2], PH[3], TX[2], P[3], PH[4], TX[3], P[4], PH[5], TX[4], P[5], PH[6], TX[5]];
for (const it of order) if (it) feed.push(it);
---

<Base title="Fareess — Health information, design & operations">
  <div class="wrap">
    <!-- editorial cover -->
    <header class="cover" id="cover">
      <div class="cover-glow" aria-hidden="true"></div>

      <div class="cover-eyebrow reveal mobile-hide">
        <span class="mono">Health information · Design · Operations</span>

      </div>

      <div class="cover-grid">
        <div class="cover-lead">
          <h1 class="masthead">
            <span class="ml reveal" style="--rd:40ms">Health</span>
            <span class="ml reveal" style="--rd:120ms">information,</span>
            <span class="ml reveal" style="--rd:200ms">made <em class="grad-text">human</em>.</span>
          </h1>
          <p class="cover-sub reveal" style="--rd:320ms">
            Clinical care reaches one person at a time; the systems behind it reach
            thousands. I design and analyze for that scale, and for the people it serves.
          </p>
          <div class="cover-actions reveal" style="--rd:400ms">
            <a class="btn btn-primary" href="/work/">Explore the work</a>
            <button type="button" class="btn btn-glass copy-email" data-copy-email>Message</button>
            <a class="btn btn-ghost" href="/resume/">Résumé</a>
          </div>
        </div>

        <aside class="cover-id reveal" style="--rd:240ms">
          <div class="id-portrait">
            <span class="ring"><img src={avatar} alt="Fareess" /></span>
            <span class="id-badge"><svg viewBox="0 0 24 24" fill="none" aria-label="Verified"><circle cx="12" cy="12" r="10" fill="var(--gold)"/><path d="M8 12.5l2.5 2.5 5-5.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </div>
          <div class="id-name">Fareess</div>
          <div class="id-handle mono">Founder, Hush Jewels · UVic '27</div>
          <div class="id-stats">
            <span><b>6</b><small>projects</small></span>
            <span><b>2020</b><small>founder</small></span>
            <span><b>Vogue</b><small>featured</small></span>
          </div>
        </aside>
      </div>

      <div class="highlights" role="group" aria-label="Highlights">
        {highlights.map((h) => (
          <button class="hl reveal" data-story={h.id} aria-label={h.label}>
            <span class="bub"><span class="inner"><svg viewBox="0 0 24 24" set:html={h.icon} /></span></span>
            <span class="lbl">{h.label}</span>
          </button>
        ))}
      </div>
    </header>

    <div class="feed-head reveal">
      <h2>Work, jewels &amp; notes</h2>
      <span class="count mono">Tap a project to read it in place</span>
    </div>

    <!-- toolbar -->
    <div class="toolbar">
      <div class="chips" role="group" aria-label="Filter">
        {['all', 'projects', 'design', 'data', 'ops', 'jewelry', 'notes'].map((t, i) => (
          <button data-tag={t} aria-pressed={i === 0 ? 'true' : 'false'}>{t === 'all' ? 'All' : t}</button>
        ))}
      </div>
      <button class="search" id="toolbar-search"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg><span class="search-label">Search</span> <kbd>⌘K</kbd></button>
    </div>

    <!-- feed -->
    <div class="feed" id="feed">
      {feed.map((it) => {
        if (it.t === 'project') {
          const e = it.e;
          const tags = `projects ${e.data.tags.join(' ')}`;
          const cover = coverFor[e.id];
          const inner = (
            <>
              <button class="heart" aria-label="Like" set:html={HEART} />
              <span class="badge">{e.data.kind === 'link' ? 'Project ↗' : 'Case study'}</span>
              {cover ? <span class="art"><img src={cover} alt={e.data.title} style="width:100%;height:100%;object-fit:cover" /></span> : <span class="art" set:html={artFor(e).svg} />}
              <span class="pbody">
                <h3>{e.data.title}</h3>
                <p>{first(e.data.summary)}</p>
                <span class="chip-row">{e.data.tags.slice(0, 3).map((t) => <span class="chip">{t}</span>)}<span class="chip hot">{e.data.end ? e.data.start.slice(0, 4) : e.data.start.slice(0, 4) + '→'}</span></span>
              </span>
            </>
          );
          return e.data.kind === 'link' ? (
            <a class="tile tile-project" href={e.data.links.github} target="_blank" rel="noopener" data-id={e.id} data-tags={tags}>{inner}</a>
          ) : (
            <div class="tile tile-project" data-slug={e.id} data-id={e.id} data-tags={tags} role="button" tabindex="0">{inner}</div>
          );
        }
        if (it.t === 'photo') {
          const p = it.p;
          return (
            <div class="tile tile-photo" data-id={p.src} data-tags="jewelry" data-full={p.src} data-alt={p.alt} data-cap={p.tag} role="button" tabindex="0">
              <button class="heart" aria-label="Like" set:html={HEART} />
              <span class="badge">{p.tag}</span>
              <img src={p.src} alt={p.alt} loading="lazy" />
              <span class="ov"><span class="cap">{p.alt}</span></span>
            </div>
          );
        }
        const x = it.x;
        return (
          <div class={`tile tile-text ${x.kind === 'stat' ? 'tile-stat' : ''} theme-${x.theme}`} data-id={`tx-${it.i}`} data-tags="notes">
            {x.kind === 'stat' ? (
              <>
                <span class="small">{x.label}</span>
                <span><span class="value">{x.value}</span><span class="note" style="display:block">{x.note}</span></span>
              </>
            ) : (
              <>
                <span class="small">{x.small}</span>
                <span class="big">{x.big}</span>
              </>
            )}
          </div>
        );
      })}
    </div>

    <footer class="foot">
      <span class="links">
        <a href="https://github.com/fareess">GitHub</a>
        <a href="https://www.linkedin.com/">LinkedIn</a>
        <a href="/colophon/">Colophon</a>
      </span>
    </footer>
  </div>

  <!-- story dialogs -->
  {highlights.map((h) => (
    <dialog class="story-dialog" id={`story-${h.id}`}>
      <div class="story">
        <div class="bars">{h.slides.map(() => <i><b></b></i>)}</div>
        <button class="sclose" aria-label="Close"><svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6 6 18"/></svg></button>
        <span class="tap left"></span><span class="tap right"></span>
        {h.slides.map((s) => (
          <div class={`slide theme-${s.theme}`}>
            <span class="kicker">{s.kicker}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            {s.cta && (s.cta.email ? (
              <button type="button" class="btn copy-email" data-copy-email>{s.cta.label}</button>
            ) : (
              <a class="btn" href={s.cta.href} data-nav>{s.cta.label}</a>
            ))}
          </div>
        ))}
      </div>
    </dialog>
  ))}
</Base>

<script>
  function initCover() {
    document.getElementById('toolbar-search')?.addEventListener('click', () => {
      const p = document.getElementById('palette') as HTMLDialogElement;
      if (p && !p.open) { p.showModal(); (p.querySelector('input') as HTMLInputElement)?.focus(); }
    });
  }
  document.addEventListener('astro:page-load', initCover);
</script>
