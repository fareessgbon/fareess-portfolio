---
import Base from '../layouts/Base.astro';
---

<Base title="Lost · Fareess">
  <div class="wrap page" style="min-height:70vh">
    <span class="mono eyebrow">404</span>
    <h1 class="big">This page <span class="grad-text">wandered off</span>.</h1>
    <p style="color:var(--ink-2); max-width:44ch; margin-top:1rem">No page lives at this address. The board, on the other hand, is right where you left it.</p>
    <a class="btn btn-primary" href="/" style="margin-top:1.4rem">Back to the feed</a>
  </div>
</Base>
